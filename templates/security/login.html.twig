{% extends 'base.html.twig' %}

{% block title %}Connexion - Pantry Stock{% endblock %}

{% block body %}
    <twig:Card class="auth-card">
        <twig:PageHeader title="Connexion" subtitle="Recevez un lien par email pour accéder à votre garde-manger." />

        {{ form_start(form) }}
            {{ form_row(form.email) }}
            <div class="form-actions">
                <twig:Button type="submit" variant="primary" label="Recevoir mon lien" />
            </div>
        {{ form_end(form) }}
    </twig:Card>
{% endblock %}
